{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "EasyFlowHub",
  "version": "0.1.1",
  "identifier": "com.yukin.easyflowhub",
  "build": {
    "beforeDevCommand": "bun run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "bun run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "label": "manager",
        "title": "EasyFlowHub",
        "width": 1000,
        "height": 700,
        "minWidth": 600,
        "minHeight": 400,
        "transparent": false,
        "alwaysOnTop": false,
        "decorations": true,
        "visible": false,
        "skipTaskbar": false,
        "center": true
      }
    ],
    "security": {
      "csp": null,
      "assetProtocol": {
        "enable": true,
        "scope": [
          "$APPDATA/**",
          "$APPLOCALDATA/**",
          "$APPCONFIG/**",
          "$RESOURCE/**"
        ]
      }
    },
    "withGlobalTauri": true
  },
  "bundle": {
    "active": true,
    "targets": ["nsis", "msi"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  },
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDIxRTJGNkE0NUREMTA5NzIKUldSeUNkRmRwUGJpSVdrUE92MW9ZZWthcUhGTmwreTVPbHhoQ0hhTjVuRFRjWHNCRUQrVkRlTEMK",
      "endpoints": [
        "https://github.com/yukin371/easyflowhub/releases/latest/download/latest.json"
      ],
      "windows": {
        "installMode": "passive"
      }
    }
  }
}
